# Copy to .env and fill in real values, then:
#   set -a && source .env && set +a
#   bash scripts/00-host-services.sh   # host stack: phoenix, token manager,
#                                      #             postgres, ETLs, postgrest
#   bash scripts/bring-up.sh           # OpenShell gateway, providers, sandbox
#
# bring-up.sh auto-sources .env if OUTLOOK_SESSION_UUID is unset, so you can
# also just run the two scripts directly after `cp .env.example .env`.
#
# 00-host-services.sh is required, not optional — without the token manager
# the Outlook bridge can't get tokens, and without postgres + postgrest the
# source-etl-query skill has no mirror to query.

# ── Inference (the agent's LLM) ──────────────────────────────────────────
# At least one API key is required for the agent to call any LLM. If both
# are unset, bring-up.sh skips the inference provider and warns.
# COMPATIBLE_API_KEY is preferred; OPENAI_API_KEY is also accepted.
#
# For the default NemoClaw endpoint, get a key from https://build.nvidia.com:
# sign in, open any model page, and click "Get API Key". The key may start
# with `nvapi-` or `sk-` depending on the backend.
COMPATIBLE_API_KEY=
NEMOCLAW_ENDPOINT_URL=https://integrate.api.nvidia.com/v1
NEMOCLAW_MODEL=nvidia/nemotron-3-super-120b-a12b
#
# Corporate VPN / split-horizon DNS / local-CA hosts: if the sandbox can't
# validate the inference endpoint's TLS chain, run scripts/host-tls-proxy.py
# on the host and point at it instead — see docs/host-tls-proxy.md.
# NEMOCLAW_ENDPOINT_URL=http://host.openshell.internal:18080/v1

# ── Outlook (required — this example is Outlook-focused) ─────────────────
# Tenant / client IDs come from your Azure app registration. The session UUID
# is generated by the MS Graph token manager during one-time auth setup —
# see docs/set-up-outlook-bridge.md.
OUTLOOK_TENANT_ID=
OUTLOOK_CLIENT_ID=
OUTLOOK_SESSION_UUID=

# Mailbox the agent reads/sends from, and the From: address it uses on replies.
OUTLOOK_TARGET_MAILBOX=agent@example.com
OUTLOOK_REPLY_TO=you@example.com

# Optional: comma-separated allowlist of senders the agent will respond to.
# Leave empty to accept any sender.
OUTLOOK_ALLOWED_SENDERS=

# Sidecar endpoint inside the sandbox. Hermes's start.sh sets this at runtime
# for processes it spawns (bridge, skills); duplicating it here lets you forward
# it into ad-hoc `openshell sandbox exec` invocations (see README "Verification")
# without sourcing /tmp/nemoclaw-proxy-env.sh inside the sandbox each time.
# Match SIDECAR_LISTEN_PORT in agents/hermes/start.sh (default 8766).
MS_GRAPH_SIDECAR_URL=http://127.0.0.1:8766

# ── Slack (required for the cross-platform showcase) ─────────────────────
# Both tokens are needed to enable the Slack channel. This example
# demonstrates cross-platform research across Slack, GitHub, NVIDIA forums,
# and Outlook — the slack-channel-finder and slack-channel-summarizer skills
# both need these tokens to read channel history and resolve references.
# SLACK_ALLOWED_IDS is an allowlist gating who can DM the agent
# (comma-separated Slack user IDs, e.g. UR0A4QL5N)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_ALLOWED_IDS=

# ── GitHub (required for a usable scrape rate) ───────────────────────────
# Used by the host-side `github-etl` container (in extras/docker-compose.yml)
# to authenticate against the GitHub API while populating the Postgres mirror
# that the source-etl-query skill reads from. Without a token, GitHub limits
# the ETL to 60 requests/hour per source IP, which is too slow for any real
# repo — tap-github will hit HTTP 403 mid-sync and fail before populating
# the mirror. With a token, the limit is 5000/hour and syncs complete.
# The sandbox itself does NOT use this token directly — github.com is not
# in the sandbox's egress policy, so agent GitHub lookups go through the
# source-etl-query skill (mirror data only), not live `gh`.
GITHUB_TOKEN=

# ── Optional: Telegram / Discord ─────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_IDS=
# DISCORD_BOT_TOKEN=

# ── Optional: observability ──────────────────────────────────────────────
# When set, bring-up.sh enables NeMo-Flow telemetry: pip-installs
# nemo-flow==0.1.0 from PyPI, applies the Hermes integration patch, and
# wires OpenInference traces to this Phoenix collector. Start the collector
# first with `docker compose -f extras/docker-compose.yml up -d phoenix`.
# PHOENIX_COLLECTOR_ENDPOINT=http://host.openshell.internal:6006/v1/traces

# ── Host-services security (TOKEN_CACHE_SALT is optional) ────────────────
# Salt for encrypting the MS Graph token manager's MSAL session cache.
# The compose default (in extras/docker-compose.yml) is shared across
# deployments — set this to a unique random string for any deployment that
# holds real Entra sessions. Generate one with: openssl rand -hex 32
# TOKEN_CACHE_SALT=

# ── Optional: bring-up overrides ─────────────────────────────────────────
# SANDBOX_NAME=hermes-direct
# Default package-managed OpenShell installs expose a local mTLS gateway at
# https://127.0.0.1:17670 under the name `openshell`.
# OPENSHELL_GATEWAY=openshell
#
# Snap installs expose a plaintext local gateway at http://127.0.0.1:17670.
# Uncomment both lines below when following deploy/snap/README.md:
# OPENSHELL_GATEWAY=snap-docker
# OPENSHELL_GATEWAY_ENDPOINT=http://127.0.0.1:17670
#
# TOKEN_MANAGER_HOST=host.openshell.internal
# SOURCE_ETL_API_HOST=host.openshell.internal
# SOURCE_ETL_API_PORT=3100
