#
# NeMo-Relay gateway plugin config — installed at /etc/nemo-relay/plugins.toml.
# Tokens substituted at image build time (see Dockerfile):
#   @@PHOENIX_ENABLED@@        — true if PHOENIX_COLLECTOR_ENDPOINT is set
#   @@PHOENIX_ENDPOINT@@       — Phoenix OTLP collector URL
#   @@PHOENIX_PROJECT_NAME@@   — openinference.project.name (Phoenix routing key;
#                                falls back to service.name when absent)
# Schema: nemo_relay.observability.ObservabilityConfig
# (NeMo-Relay crates/core/src/observability/plugin_component.rs).
#
# Per-component ATIF is local-OR-remote (sink_targets() at line ~1009), and
# only ONE `[[components]]` block with kind=observability is permitted by
# the plugin loader. When ATIF_EXPORT_MODE=relay the Dockerfile substitutes a
# `[[components.config.atif.storage]]` array entry at the storage-block token
# below — with a VESTIGIAL placeholder bucket and EMPTY key_prefix (the
# host-side relay owns the real bucket/prefix/creds). In that mode /tmp/atif/
# writes are SKIPPED (the relay forwards every completed trajectory
# downstream). When the mode is local/unset, the token expands to "" and
# trajectories are written locally — recoverable via
# scripts/download-traces.sh.

version = 1

[[components]]
kind = "observability"
enabled = true

[components.config.atif]
enabled = true
output_directory = "/tmp/atif"
@@ATIF_STORAGE_BLOCK@@

[components.config.openinference]
enabled = @@PHOENIX_ENABLED@@
transport = "http_binary"
endpoint = "@@PHOENIX_ENDPOINT@@"
service_name = "hermes-agent"
timeout_millis = 3000

[components.config.openinference.resource_attributes]
"openinference.project.name" = "@@PHOENIX_PROJECT_NAME@@"
