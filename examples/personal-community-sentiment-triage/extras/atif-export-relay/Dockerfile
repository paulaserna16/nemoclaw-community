FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

# ca-certificates: TLS to S3 / MinIO. curl + bash: ops/debugging.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
       bash ca-certificates curl tzdata \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    "aiohttp>=3.10,<4" \
    "boto3>=1.35,<2"

COPY relay.py /app/relay.py
COPY backends/ /app/backends/

# Sandbox credentials (bearer tokens) come from the host's .env via compose
# env injection (no config files inside the image). TLS cert + key for the
# HTTPS listener come from a host bind-mount at /etc/atif-export-relay/tls/
# (server.crt, server.key) — generated by scripts/00-host-services.sh on
# bring-up via extras/atif-export-relay/generate-tls-cert.sh. See
# docs/atif-export.md "Sandbox→relay TLS via Python protocol-bridge
# sidecar" for the architecture overview.
ENTRYPOINT ["python", "-u", "/app/relay.py"]
